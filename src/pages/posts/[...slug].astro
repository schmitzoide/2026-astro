---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { formatDateLong } from "../../lib/format";
import { SITE } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { data } = post;

const all = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
const idx = all.findIndex((p) => p.id === post.id);
const prev = all[idx + 1];
const next = all[idx - 1];

const minutes = Math.max(1, Math.round(data.wordCount / 220));
const url = new URL(`/posts/${post.id}/`, SITE.url).toString();

const articleLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: data.title,
  description: data.description,
  datePublished: data.publishDate.toISOString(),
  dateModified: data.updatedDate.toISOString(),
  author: {
    "@type": "Person",
    name: SITE.author,
    url: SITE.url,
    sameAs: SITE.sameAs,
  },
  publisher: {
    "@type": "Person",
    name: SITE.author,
    url: SITE.url,
  },
  keywords: data.tags.join(", "),
  articleSection: data.categoryName,
  wordCount: data.wordCount,
  inLanguage: SITE.locale,
  url,
  mainEntityOfPage: url,
};

const breadcrumbsLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Writing", item: SITE.url },
    { "@type": "ListItem", position: 2, name: data.title, item: url },
  ],
};
---

<Base
  title={data.title}
  description={data.description}
  article={{
    publishedTime: data.publishDate.toISOString(),
    modifiedTime: data.updatedDate.toISOString(),
    tags: data.tags,
  }}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbsLd)} />

  <article class="mx-auto max-w-5xl px-6 lg:px-10 pt-10 sm:pt-16" aria-labelledby="post-title">
    <a
      href="/"
      class="font-mono text-[12px] text-[color:var(--fg-soft)] hover:text-[color:var(--accent)] transition-colors inline-flex items-center gap-1.5 py-2 -my-2"
    >
      <span aria-hidden="true">←</span> All writing
    </a>

    <header class="mt-10 sm:mt-14 max-w-3xl">
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 font-mono text-[12px] text-[color:var(--fg-soft)] mb-6">
        <span class="text-[color:var(--accent)]">/{data.category}</span>
        <span aria-hidden="true">·</span>
        <time datetime={data.publishDate.toISOString()}>{formatDateLong(data.publishDate)}</time>
        <span aria-hidden="true">·</span>
        <span aria-label={`${minutes} minute read`}>{minutes} min read</span>
      </div>
      <h1 id="post-title" class="font-serif text-[clamp(2rem,5vw,3.75rem)] leading-[1.05] tracking-[-0.02em] font-light text-balance">
        {data.title}
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-[color:var(--fg-soft)] leading-relaxed">
        {data.description}
      </p>
    </header>

    <div class="mt-14 max-w-3xl">
      <div class="prose-reader" set:html={data.contentHtml} />
    </div>

    <nav
      class="mt-20 pt-10 border-t border-[color:var(--rule)] grid sm:grid-cols-2 gap-6"
      aria-label="More writing"
    >
      {prev ? (
        <a href={`/posts/${prev.id}/`} class="group block" rel="prev">
          <p class="font-mono text-[11px] uppercase tracking-wider text-[color:var(--fg-soft)]">
            <span aria-hidden="true">←</span> Older
          </p>
          <p class="mt-1 font-serif text-lg leading-snug group-hover:text-[color:var(--accent)] transition-colors">{prev.data.title}</p>
        </a>
      ) : <span />}
      {next ? (
        <a href={`/posts/${next.id}/`} class="group block sm:text-right" rel="next">
          <p class="font-mono text-[11px] uppercase tracking-wider text-[color:var(--fg-soft)]">
            Newer <span aria-hidden="true">→</span>
          </p>
          <p class="mt-1 font-serif text-lg leading-snug group-hover:text-[color:var(--accent)] transition-colors">{next.data.title}</p>
        </a>
      ) : <span />}
    </nav>
  </article>
</Base>
