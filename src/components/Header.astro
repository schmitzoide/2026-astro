---
import { SITE, NAV } from "../lib/site";
const path = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 backdrop-blur-md bg-[color:var(--bg)]/80 border-b border-[color:var(--rule)]"
  role="banner"
>
  <div class="mx-auto max-w-5xl px-6 lg:px-10 min-h-14 flex items-center justify-between gap-4">
    <a
      href="/"
      class="font-mono text-[13px] tracking-tight hover:text-[color:var(--accent)] transition-colors py-3 -my-3"
      aria-label={`${SITE.name}, home`}
    >
      <span class="text-[color:var(--fg-soft)]" aria-hidden="true">~/</span>marcel<span class="text-[color:var(--fg-soft)]" aria-hidden="true">.schmitz</span>
    </a>
    <nav class="flex items-center gap-0.5 sm:gap-1 font-mono text-[13px]" aria-label="Primary">
      {NAV.map((item) => {
        const active = item.href === "/" ? path === "/" : path.startsWith(item.href);
        const external = item.href.startsWith("http");
        return (
          <a
            href={item.href}
            class:list={[
              "px-2.5 py-3 -my-1 rounded transition-colors min-h-11 inline-flex items-center",
              active ? "text-[color:var(--accent)]" : "text-[color:var(--fg-soft)] hover:text-[color:var(--fg)]",
            ]}
            target={external ? "_blank" : undefined}
            rel={external ? "noopener noreferrer" : undefined}
            aria-current={active ? "page" : undefined}
          >
            {item.label}{external && <span aria-hidden="true" class="ml-0.5 opacity-50">↗</span>}
          </a>
        );
      })}
      <button
        id="theme-toggle"
        type="button"
        class="ml-1 px-2.5 py-3 -my-1 rounded font-mono text-[13px] text-[color:var(--fg-soft)] hover:text-[color:var(--fg)] transition-colors min-h-11 min-w-11 inline-flex items-center justify-center"
        aria-label="Switch to dark theme"
        aria-pressed="false"
      >
        <span class="hidden dark:inline" aria-hidden="true">☀</span>
        <span class="inline dark:hidden" aria-hidden="true">☾</span>
      </button>
    </nav>
  </div>
</header>

<script>
  const syncToggle = () => {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;
    const isDark = document.documentElement.classList.contains("dark");
    btn.setAttribute("aria-pressed", String(isDark));
    btn.setAttribute(
      "aria-label",
      isDark ? "Switch to light theme" : "Switch to dark theme",
    );
  };

  const setup = () => {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;
    syncToggle();
    if (btn.dataset.bound === "1") return;
    btn.dataset.bound = "1";
    btn.addEventListener("click", () => {
      const root = document.documentElement;
      const isDark = root.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
      syncToggle();
    });
  };

  setup();
  document.addEventListener("astro:after-swap", setup);
</script>
